# Claude API key (required for task execution)
ANTHROPIC_API_KEY=sk-ant-...

# Transport mode: stdio (default) | streamable-http
# CLAUDE_AGENT_MCP_TRANSPORT=stdio

# Network transport settings (only used when TRANSPORT=streamable-http)
# CLAUDE_AGENT_MCP_HOST=127.0.0.1
# CLAUDE_AGENT_MCP_PORT=8000

# State storage directory (default: .state in working directory)
# CLAUDE_AGENT_MCP_STATE_DIR=.state

# SQLite database path override (default: <state_dir>/claude-agent-mcp.db)
# CLAUDE_AGENT_MCP_DB_PATH=

# Artifact storage directory override (default: <state_dir>/artifacts)
# CLAUDE_AGENT_MCP_ARTIFACT_DIR=

# Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_AGENT_MCP_MODEL=claude-sonnet-4-6

# Session lock TTL in seconds (default: 300)
# CLAUDE_AGENT_MCP_LOCK_TTL=300

# Allowed working directories (comma-separated, default: current directory)
# CLAUDE_AGENT_MCP_ALLOWED_DIRS=/home/user/projects,/tmp/workspace

# Max artifact size in bytes (default: 10MB)
# CLAUDE_AGENT_MCP_MAX_ARTIFACT_BYTES=10485760

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL (default: INFO)
# CLAUDE_AGENT_MCP_LOG_LEVEL=INFO
