# Claude API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# State storage directory (default: .state in working directory)
# CLAUDE_AGENT_STATE_DIR=.state

# Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_AGENT_MODEL=claude-sonnet-4-6

# Session lock TTL in seconds (default: 300)
# CLAUDE_AGENT_LOCK_TTL_SECONDS=300

# Allowed working directories (comma-separated, default: current directory)
# CLAUDE_AGENT_ALLOWED_DIRS=/home/user/projects,/tmp/workspace

# Max artifact size in bytes (default: 10MB)
# CLAUDE_AGENT_MAX_ARTIFACT_BYTES=10485760

# Log level (default: INFO)
# CLAUDE_AGENT_LOG_LEVEL=INFO
